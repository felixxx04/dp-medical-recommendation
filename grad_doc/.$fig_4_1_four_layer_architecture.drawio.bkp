<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="29.7.9">
  <diagram name="四层推荐架构图" id="four-layer-architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0" background="#ffffff">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="四层推荐安全架构" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 输入：患者症状/疾病 -->
        <mxCell id="input" value="患者输入&#xa;（口语化疾病/症状）" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- 患者口语增强模块 -->
        <mxCell id="enhancer" value="PatientInputEnhancer&#xa;患者口语增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="260" y="100" width="160" height="70" as="geometry" />
        </mxCell>

        <!-- 箭头：输入→口语增强 -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1.5;strokeColor=#000000;endArrow=block;endFill=1;" edge="1" parent="1" source="input" target="enhancer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ 第零层：临床知识路由层 ============ -->
        <mxCell id="layer0_container" value="第零层：临床知识路由层 (KnowledgeRouter)" style="swimlane;startSize=30;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;swimlaneFillColor=#ffffff;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="460" y="60" width="680" height="150" as="geometry" />
        </mxCell>

        <!-- L1 -->
        <mxCell id="l1" value="L1 口语标准化&#xa;154条映射" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontColor=#000000;" vertex="1" parent="layer0_container">

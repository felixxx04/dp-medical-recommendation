        <mxCell id="soft_rules" value="软标记规则&#xa;（9条，医生可审核）&#xa;相对禁忌/超说明书用药等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontColor=#000000;" vertex="1" parent="layer1_container">
